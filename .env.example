# Obzorarr Environment Configuration
#
# Values containing & * # $ ! or other shell-special characters
# MUST be wrapped in single quotes or escaped, e.g.:
#   PLEX_TOKEN='abc&def$ghi'
# Do NOT use double quotes (they preserve $ expansion).
# `source .env` works only with quoted values; `dotenv-cli` is more robust.

# =============================================================================
# REQUIRED
# =============================================================================
# Plex Media Server connection
# Find your token: https://support.plex.tv/articles/204059436
PLEX_SERVER_URL=http://localhost:32400
PLEX_TOKEN=your-plex-token-here

# =============================================================================
# OPTIONAL (defaults shown)
# =============================================================================

# Server
# PORT=3000
# HOST=0.0.0.0
# ORIGIN=https://your-domain.com    # Required for CSRF protection in production
# TRUST_PROXY=false                 # Set to "true" only if your reverse proxy strips inbound X-Forwarded-* headers from clients

# Database
# DATABASE_PATH=data/obzorarr.db

# Sync schedule (cron format)
# SYNC_CRON_SCHEDULE=0 */6 * * *
# METADATA_CONCURRENCY=8
# ENABLE_LIVE_SYNC=true

# AI Fun Facts (leave empty to use templates instead)
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini

# =============================================================================
# DEVELOPMENT ONLY (ignored in production)
# =============================================================================

# Bypass Plex OAuth in dev mode
# DEV_BYPASS_AUTH=true
# DEV_BYPASS_USER=              # empty=owner, "random", <plexId>, or <username>
# DEV_PLEX_TOKEN=               # Valid Plex.tv token for onboarding testing (use when PLEX_TOKEN is empty)
